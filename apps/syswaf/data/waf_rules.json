  "rules": [
    {
      "rule_id": "sql-001",
      "name": "SQL注入 - UNION注入",
      "category_id": 1,
      "severity": "high",
      "pattern": "(?i)(union\\s+(all\\s+)?select)",
      "targets": "[\"url\", \"post\", \"cookie\"]",
      "description": "检测UNION SELECT类型的SQL注入攻击",
      "is_builtin": true
    },
